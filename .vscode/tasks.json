{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Run Flask App",
			"type": "shell",
			"command": "python app.py",
			"isBackground": true
		},
		{
			"label": "Run Flask App (with venv)",
			"type": "shell",
			"command": ".venv\\Scripts\\activate && python app.py",
			"isBackground": true
		},
		{
			"label": "Run Flask App",
			"type": "shell",
			"command": ".venv\\Scripts\\activate.ps1 ; python app.py",
			"isBackground": true
		},
		{
			"label": "Run Flask App",
			"type": "shell",
			"command": ".venv\\Scripts\\python.exe app.py",
			"isBackground": true
		}
	]
}